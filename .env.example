# ===========================================
# HustSimulator V2 - Environment Variables
# ===========================================

# PostgreSQL + PostGIS
POSTGRES_DB=hustsimulator
POSTGRES_USER=hustsim
POSTGRES_PASSWORD=hustsim_secret
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=hustsim_redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=hustsim
RABBITMQ_PASSWORD=hustsim_rabbit
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Game Server (NestJS)
GAME_SERVER_PORT=3000
GAME_SERVER_WS_PORT=3001
GAME_SERVER_GRPC_PORT=50051

# Context Service (Spring Boot)
CONTEXT_SERVICE_PORT=8080
CONTEXT_SERVICE_GRPC_PORT=50052
